# --- Stripe ---
# Server-side secret key. Used by api/create-checkout-session.ts on Vercel.
# Get from https://dashboard.stripe.com/apikeys (use test key sk_test_... in dev).
STRIPE_SECRET_KEY=sk_test_replace_me

# Public key, exposed to the browser. Same dashboard.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# --- Google Calendar booking ---
# Tiaera's Google Appointment Schedule embed URL.
# From Google Calendar: Settings -> Appointment Schedules -> open her schedule ->
# "Share" -> copy the booking page URL and append ?gv=true so it embeds cleanly.
# Example: https://calendar.google.com/calendar/appointments/schedules/AcZssZ.../select?gv=true
VITE_BOOKING_EMBED_URL=https://calendar.google.com/calendar/u/0?cid=MWFiZmQwMjQzMzliZjFkMTliMzVmNzI0YmJjYTZlODRiMWI3NWNiZGUwZjU4MmNiNmQwOWNkYTM2NDc5NzU0N0Bncm91cC5jYWxlbmRhci5nb29nbGUuY29t
